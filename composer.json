{
    "name" : "oihana/php-memcached" ,
    "type" : "library" ,
    "description" : "The Oihana PHP memcached library — Memcached CRUD wrapper, console commands, PSR-16 cache via Scrapbook, and a production-grade RateLimitStore for oihana/php-middleware." ,
    "keywords" : [ "php" , "memcached" , "command" , "console" , "rate-limit" , "rate-limiting" , "psr-7" , "middleware" ] ,
    "homepage" : "https://github.com/BcommeBois/oihana-php-memcached" ,
    "license" : "MPL-2.0" ,
    "authors" : [
        {
            "name" : "Marc Alcaraz" ,
            "email" : "marc@ooop.fr" ,
            "homepage" : "https://www.ooop.fr" ,
            "role" : "Project Founder, Lead Developer."
        }
    ],
    "support": {
        "email": "marc@ooop.fr"
    },
    "scripts": {
        "console": "bin/console",
        "memcached": "@console command:memcached",
        "doc": "rm -rf docs && mkdir docs && cp -r assets docs/assets && ./vendor/bin/phpdoc -c phpdoc.xml -v" ,
        "test": "./vendor/bin/phpunit",
        "coverage": "XDEBUG_MODE=coverage ./vendor/bin/phpunit -c phpunit-integration.xml --coverage-text --coverage-clover build/coverage/clover.xml --coverage-html build/coverage/html",
        "coverage:md": [
            "@coverage",
            "php tools/clover-to-markdown.php build/coverage/clover.xml build/coverage/COVERAGE.md"
        ]
    },
    "autoload": {
        "psr-4" :
        {
            "oihana\\" : "src/oihana"
        },
        "files":[
            "src/oihana/memcached/helpers/cacheCollection.php" ,
            "src/oihana/memcached/helpers/getMemcached.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "tests\\" : "tests"
        }
    },
    "require": {
        "php": ">=8.4",
        "ext-memcached" : "*",
        "oihana/php-core": "dev-main",
        "oihana/php-exceptions": "dev-main",
        "oihana/php-reflect": "dev-main",
        "oihana/php-enums": "dev-main",
        "oihana/php-files": "dev-main",
        "oihana/php-controllers": "dev-main",
        "oihana/php-routes": "dev-main",
        "oihana/php-init": "dev-main",
        "oihana/php-models": "dev-main",
        "oihana/php-commands": "dev-main",
        "oihana/php-schema": "dev-main",
        "oihana/php-signals": "dev-main",
        "oihana/php-standards": "dev-main",
        "oihana/php-middleware": "dev-main",
        "matthiasmullie/scrapbook": "^1.5",
        "symfony/console": "^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12",
        "nunomaduro/collision": "^8.8",
        "mikey179/vfsstream": "^1.6",
        "phpdocumentor/shim": "^3.8"
    },
    "minimum-stability" : "dev" ,
    "prefer-stable" : true ,
    "config": {
        "allow-plugins": {
            "phpdocumentor/shim": true
        }
    }
}
